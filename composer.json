{
    "name": "kwtsms/laravel-kwtsms",
    "description": "Laravel notification channel for the kwtSMS SMS gateway (Kuwait)",
    "type": "library",
    "keywords": ["kwtsms", "sms", "laravel", "notification", "kuwait", "otp"],
    "homepage": "https://www.kwtsms.com",
    "license": "MIT",
    "authors": [
        {
            "name": "kwtSMS",
            "email": "support@kwtsms.com",
            "homepage": "https://www.kwtsms.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/notifications": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "kwtsms/kwtsms": "^1.2"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "autoload": {
        "psr-4": {
            "KwtSMS\\Laravel\\": "src/",
            "KwtSMS\\Laravel\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KwtSMS\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "KwtSMS\\Laravel\\KwtSmsServiceProvider"
            ],
            "aliases": {
                "KwtSms": "KwtSMS\\Laravel\\Facades\\KwtSms"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
